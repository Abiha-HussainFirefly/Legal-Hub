  notifications      Notification[]
  gamificationEvents GamificationEvent[]
  revisions          CommentRevision[]

  @@index([discussionId, createdAt])
  @@index([answerId, createdAt])
  @@index([caseId, createdAt])
  @@index([authorId, createdAt])
  @@index([parentId])
}

