}

model CaseView {
  id        String   @id @default(cuid())
  caseId    String
  userId    String?
  ipHash    String?
  userAgent String?
  viewedAt  DateTime @default(now())

  caseRecord CaseRecord @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([caseId, viewedAt])
  @@index([userId, viewedAt])
}

model ContentReport {
  id             String            @id @default(cuid())
  reporterId     String
  reportedUserId String?
  discussionId   String?
  answerId       String?
  commentId      String?
  caseId         String?
  targetType     ContentTargetType
  reason         ReportReason
  description    String?
  status         ReportStatus      @default(OPEN)
  reviewedById   String?
  reviewedAt     DateTime?
  resolutionNote String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  reporter          User               @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser      User?              @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  discussion        Discussion?        @relation(fields: [discussionId], references: [id], onDelete: SetNull)
  answer            Answer?            @relation(fields: [answerId], references: [id], onDelete: SetNull)
  comment           Comment?           @relation(fields: [commentId], references: [id], onDelete: SetNull)
  caseRecord        CaseRecord?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  reviewedBy        User?              @relation("ReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  moderationActions ModerationAction[]

  @@index([reporterId, createdAt])
  @@index([status, createdAt])
  @@index([targetType, createdAt])
  @@index([reviewedById])
}

model AIAlert {
  id           String            @id @default(cuid())
  source       String
  targetType   ContentTargetType
  discussionId String?
  answerId     String?
  commentId    String?
  caseId       String?
  severity     AIAlertSeverity
  title        String
  description  String?
  riskScore    Decimal?          @db.Decimal(5, 2)
  status       AIAlertStatus     @default(OPEN)
  reviewedById String?
  reviewedAt   DateTime?
  detectedAt   DateTime          @default(now())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  discussion        Discussion?        @relation(fields: [discussionId], references: [id], onDelete: SetNull)
  answer            Answer?            @relation(fields: [answerId], references: [id], onDelete: SetNull)
  comment           Comment?           @relation(fields: [commentId], references: [id], onDelete: SetNull)
  caseRecord        CaseRecord?        @relation(fields: [caseId], references: [id], onDelete: SetNull)
  reviewedBy        User?              @relation("AIAlertReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  moderationActions ModerationAction[]

  @@index([status, severity, detectedAt])
  @@index([targetType, detectedAt])
  @@index([reviewedById])
}

model ModerationAction {
  id           String               @id @default(cuid())
  moderatorId  String
  targetUserId String?
  discussionId String?
  answerId     String?
  commentId    String?
  caseId       String?
  reportId     String?
  aiAlertId    String?
  actionType   ModerationActionType
  reason       String?
  note         String?
  createdAt    DateTime             @default(now())

  moderator  User           @relation("ModerationActor", fields: [moderatorId], references: [id], onDelete: Restrict)
  targetUser User?          @relation("ModerationTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  discussion Discussion?    @relation(fields: [discussionId], references: [id], onDelete: SetNull)
  answer     Answer?        @relation(fields: [answerId], references: [id], onDelete: SetNull)
  comment    Comment?       @relation(fields: [commentId], references: [id], onDelete: SetNull)
  caseRecord CaseRecord?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  report     ContentReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  aiAlert    AIAlert?       @relation(fields: [aiAlertId], references: [id], onDelete: SetNull)

  @@index([moderatorId, createdAt])
  @@index([actionType, createdAt])
  @@index([targetUserId])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  actorId        String?
  discussionId   String?
  answerId       String?
  commentId      String?
  caseId         String?
  organizationId String?
  type           NotificationType
  title          String
  message        String?
  data           Json?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  user         User          @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor        User?         @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  discussion   Discussion?   @relation(fields: [discussionId], references: [id], onDelete: SetNull)
  answer       Answer?       @relation(fields: [answerId], references: [id], onDelete: SetNull)
  comment      Comment?      @relation(fields: [commentId], references: [id], onDelete: SetNull)
  caseRecord   CaseRecord?   @relation(fields: [caseId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([type, createdAt])
}
