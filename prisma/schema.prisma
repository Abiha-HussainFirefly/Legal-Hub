model Discussion {
  id               String            @id @default(cuid())
  slug             String            @unique
  kind             DiscussionType    @default(DISCUSSION)
  title            String
  body             String
  excerpt          String?
  authorId         String
  organizationId   String?
  categoryId       String
  regionId         String?
  relatedCaseId    String?
  status           DiscussionStatus  @default(OPEN)
  visibility       ContentVisibility @default(PUBLIC)
  contentStatus    ContentStatus     @default(ACTIVE)
  acceptedAnswerId String?           @unique
  resolvedById     String?
  resolvedAt       DateTime?
  score            Int               @default(0)
  reactionCount    Int               @default(0)
  answerCount      Int               @default(0)
  commentCount     Int               @default(0)
  viewCount        Int               @default(0)
  followerCount    Int               @default(0)
  bookmarkCount    Int               @default(0)
  boostCount       Int               @default(0)
  isPinned         Boolean           @default(false)
  pinnedUntil      DateTime?
  sourceUrl        String?
  effectiveDate    DateTime?
  isAiSummaryReady Boolean           @default(false)
  lastActivityAt   DateTime          @default(now())
  closedAt         DateTime?
  lockedAt         DateTime?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  author             User                  @relation("DiscussionAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  organization       Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  category           Category              @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  region             Region?               @relation(fields: [regionId], references: [id], onDelete: SetNull)
  relatedCase        CaseRecord?           @relation("DiscussionRelatedCase", fields: [relatedCaseId], references: [id], onDelete: SetNull)
  answers            Answer[]              @relation("DiscussionAnswers")
  acceptedAnswer     Answer?               @relation("AcceptedDiscussionAnswer", fields: [acceptedAnswerId], references: [id], onDelete: SetNull)
  resolvedBy         User?                 @relation("DiscussionResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
