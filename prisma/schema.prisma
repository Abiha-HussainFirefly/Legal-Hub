generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  SYSTEM
  EXTERNAL
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
  DELETED
}

enum IdentifierType {
  EMAIL
  PHONE
}

enum AuthProviderType {
  CREDENTIALS
  OAUTH
  SAML
  OIDC
}

enum MfaFactorType {
  TOTP
  SMS
  EMAIL
  WEBAUTHN
}

enum MfaFactorStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum AuditCategory {
  AUTH
  SECURITY
  USER
  CONTENT
  CASE_REPOSITORY
  MODERATION
  VERIFICATION
  ORGANIZATION
  SYSTEM
}

enum RegionType {
  COUNTRY
  FEDERAL
  PROVINCE
  STATE
  CITY
  DISTRICT
}

enum LawyerVerificationStatus {
  NOT_SUBMITTED
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
}

enum VerificationDocumentType {
  BAR_LICENSE
  BAR_COUNCIL_CARD
  PRACTICING_CERTIFICATE
  NATIONAL_ID
  PROFILE_PHOTO
  OTHER
}

enum OrganizationType {
  LAW_FIRM
  BAR_ASSOCIATION
  LAW_SCHOOL
  GOVERNMENT
  NGO
  COMMUNITY
  OTHER
}

enum OrganizationVisibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum OrganizationMemberRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

enum OrganizationMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
  LEFT
}

enum CategoryScope {
  DISCUSSION
  CASE
  BOTH
  LAWYER_PRACTICE
}

enum DiscussionType {
  QUESTION
  DISCUSSION
  ANNOUNCEMENT
  LEGAL_UPDATE
}

enum DiscussionStatus {
  OPEN
  RESOLVED
  CLOSED
  LOCKED
  HIDDEN
  DELETED
}

enum ContentVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
  ORGANIZATION
}

enum ContentStatus {
  DRAFT
  ACTIVE
  PENDING_MODERATION
  FLAGGED
  HIDDEN
  REMOVED
  DELETED
}

enum ReactionType {
  LIKE
  UPVOTE
  DOWNVOTE
  HELPFUL
  INSIGHTFUL
  LOVE
  HAPPY
  UNHAPPY
}

enum TagType {
  PRACTICE_AREA
  TOPIC
  TREND
  SPECIALTY
  LEGAL_CONCEPT
}

enum SummaryStatus {
  PENDING
  GENERATED
  FAILED
  STALE
}

enum ContentTargetType {
  USER
  ORGANIZATION
  DISCUSSION
  ANSWER
  COMMENT
  CASE
}

enum ReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  MISINFORMATION
  LEGAL_RISK
  COPYRIGHT
  PRIVACY
  FRAUD
  OFF_TOPIC
  UNAUTHORIZED_PRACTICE
  SENSITIVE_PII
  DEFAMATION
  OTHER
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  ACTIONED
  DISMISSED
  RESOLVED
}

enum AIAlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AIAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  FALSE_POSITIVE
}

enum ModerationActionType {
  WARNING
  NOTE_ADDED
  CONTENT_HIDDEN
  CONTENT_REMOVED
  CONTENT_RESTORED
  USER_SUSPENDED
  USER_BANNED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  CASE_PUBLISHED
  CASE_REJECTED
}

enum NotificationType {
  NEW_ANSWER
  ANSWER_ACCEPTED
  DISCUSSION_FOLLOWED
  DISCUSSION_MENTIONED
  COMMENT_REPLIED
  CASE_PUBLISHED
  CASE_UPDATED
  CASE_COMMENTED
  BADGE_AWARDED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  REPORT_UPDATE
  AI_SUMMARY_READY
  ORGANIZATION_INVITE
  SYSTEM
}

enum CaseSourceType {
  USER_SUBMITTED
  OFFICIAL_COURT
  IMPORTED_EDITORIAL
  COMMUNITY_CURATED
}

enum RepositoryItemStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
  REMOVED
}

enum CourtLevel {
  LOCAL
  DISTRICT
  HIGH
  APPELLATE
  SUPREME
  TRIBUNAL
  OTHER
}

enum GamificationEventType {
  DISCUSSION_CREATED
  ANSWER_POSTED
  COMMENT_POSTED
  ANSWER_ACCEPTED
  DISCUSSION_REACTION_RECEIVED
  ANSWER_REACTION_RECEIVED
  COMMENT_REACTION_RECEIVED
  CASE_SUBMITTED
  CASE_PUBLISHED
  CASE_REACTION_RECEIVED
  DISCUSSION_BOOSTED
  LAWYER_VERIFIED
  BADGE_AWARDED
  MANUAL_ADJUSTMENT
}

enum FileScanStatus {
  PENDING
  CLEAN
  INFECTED
  FAILED
}

enum BoostType {
  BUMP
  FEATURE
  PIN
}

enum ProfileVisibilityLevel {
  PUBLIC
  MEMBERS_ONLY
  LAWYERS_ONLY
  PRIVATE
}

enum ProfileCompletionState {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ConsultationAvailability {
  AVAILABLE
  LIMITED
  UNAVAILABLE
}

model User {
  id       String     @id @default(cuid())
  userType UserType   @default(EXTERNAL)
  status   UserStatus @default(ACTIVE)

  displayName String?
  avatarUrl   String?
  locale      String? @default("en")
  timeZone    String?

  lastLoginAt   DateTime?
  lastLoginIp   String?
  lastUserAgent String?
  deletedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identifiers        UserIdentifier[]
  credential         Credential?
  externalAccounts   ExternalAccount[]
  sessions           Session[]
  mfaFactors         MfaFactor[]
  mfaRecoveryCodes   MfaRecoveryCode[]
  roles              UserRole[]
  rolesAssigned      UserRole[]          @relation("UserRoleAssignedBy")
  auditLogs          AuditLog[]          @relation("AuditActor")
  auditTargets       AuditLog[]          @relation("AuditTarget")
  verificationTokens VerificationToken[]
  loginAttempts      LoginAttempt[]

  profile              UserProfile?
  profileVisibility    UserProfileVisibility?
  stats                UserStats?
  gamification         UserGamification?
  lawyerProfile        LawyerProfile?
  experiences          UserExperience[]
  educations           UserEducation[]
  certifications       UserCertification[]
  skills               UserSkill[]
  languages            UserLanguage[]
  awards               UserAward[]
  socialLinks          UserSocialLink[]
  profileViewsReceived UserProfileView[]      @relation("ProfileViewsReceived")
  profileViewsGiven    UserProfileView[]      @relation("ProfileViewsGiven")
  activityDaily        UserActivityDaily[]

  organizationsOwned      Organization[]       @relation("OrganizationOwner")
  organizationMemberships OrganizationMember[]
  organizationInvitesSent OrganizationMember[] @relation("OrganizationMemberInvitedBy")

  discussions           Discussion[]         @relation("DiscussionAuthor")
  resolvedDiscussions   Discussion[]         @relation("DiscussionResolvedBy")
  answers               Answer[]             @relation("AnswerAuthor")
  comments              Comment[]            @relation("CommentAuthor")
  caseRecords           CaseRecord[]         @relation("CaseAuthor")
  reviewedCases         CaseRecord[]         @relation("CaseReviewedBy")
  caseRevisions         CaseRevision[]       @relation("CaseRevisionEditor")
  reviewedCaseRevisions CaseRevision[]       @relation("CaseRevisionReviewedBy")
  discussionRevisions   DiscussionRevision[] @relation("DiscussionRevisionEditor")
  answerRevisions       AnswerRevision[]     @relation("AnswerRevisionEditor")
  commentRevisions      CommentRevision[]    @relation("CommentRevisionEditor")

  discussionReactions DiscussionReaction[]
  answerReactions     AnswerReaction[]
  commentReactions    CommentReaction[]
  caseReactions       CaseReaction[]
  discussionFollows   DiscussionFollow[]
  caseFollows         CaseFollow[]
  savedDiscussions    SavedDiscussion[]
  savedCases          SavedCase[]
  discussionViews     DiscussionView[]
  caseViews           CaseView[]
  discussionBoosts    DiscussionBoost[]
  gamificationEvents  GamificationEvent[]
  badges              UserBadge[]
  badgesAwarded       UserBadge[]          @relation("BadgeAwardedBy")

  fileAssets         FileAsset[]           @relation("AssetUploader")
  contentAttachments ContentAttachment[]   @relation("AttachmentUploader")
  generatedSummaries DiscussionAISummary[] @relation("AISummaryGeneratedBy")
  notifications      Notification[]        @relation("NotificationRecipient")
  notificationActors Notification[]        @relation("NotificationActor")

  verificationReviews       LawyerVerificationRequest[] @relation("VerificationReviewedBy")
  verifiedLawyers           LawyerProfile[]             @relation("LawyerVerifiedBy")
  reportsSubmitted          ContentReport[]             @relation("ReportReporter")
  reportsAgainst            ContentReport[]             @relation("ReportedUser")
  reportReviews             ContentReport[]             @relation("ReportReviewer")
  reviewedAlerts            AIAlert[]                   @relation("AIAlertReviewer")
  moderationActionsTaken    ModerationAction[]          @relation("ModerationActor")
  moderationActionsReceived ModerationAction[]          @relation("ModerationTargetUser")

  @@index([userType, status])
  @@index([createdAt])
}

model UserIdentifier {
  id              String         @id @default(cuid())
  userId          String
  type            IdentifierType
  value           String
  normalizedValue String
  isPrimary       Boolean        @default(false)
  verifiedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([type, normalizedValue])
  @@index([userId, type])
  @@index([userId, isPrimary])
}

model Credential {
  id             String    @id @default(cuid())
  userId         String    @unique
  passwordHash   String
  passwordAlgo   String?
  passwordParams Json?
  passwordSetAt  DateTime  @default(now())
  mustRotate     Boolean   @default(false)
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExternalAccount {
  id     String @id @default(cuid())
  userId String

  providerType      AuthProviderType @default(OAUTH)
  provider          String
  providerAccountId String

  providerEmail       String?
  providerDisplayName String?
  providerAvatarUrl   String?
  providerProfile     Json?

  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  idTokenEncrypted      String?
  tokenType             String?
  scope                 String?
  expiresAt             Int?
  refreshTokenExpiresAt Int?
  sessionState          String?

  linkedAt   DateTime  @default(now())
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
  @@index([provider, providerEmail])
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  sessionTokenHash String    @unique
  refreshTokenHash String?   @unique
  sessionFamilyId  String?
  ip               String?
  userAgent        String?
  deviceLabel      String?
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?
  revokeReason     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model MfaFactor {
  id              String          @id @default(cuid())
  userId          String
  type            MfaFactorType
  status          MfaFactorStatus @default(PENDING)
  label           String?
  secretEncrypted String?
  credentialId    String?         @unique
  publicKey       String?
  counter         Int?
  phoneNumber     String?
  emailAddress    String?
  lastUsedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, status])
}

model MfaRecoveryCode {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String    @unique
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
}

model VerificationToken {
  id              String          @id @default(cuid())
  userId          String?
  purpose         String
  tokenHash       String          @unique
  expiresAt       DateTime
  consumedAt      DateTime?
  identifierType  IdentifierType?
  identifierValue String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([purpose, expiresAt])
  @@index([userId, purpose])
}

model LoginAttempt {
  id              String          @id @default(cuid())
  userId          String?
  identifierType  IdentifierType?
  identifierValue String?
  success         Boolean
  failureReason   String?
  ipHash          String?
  userAgent       String?
  createdAt       DateTime        @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([identifierType, identifierValue, createdAt])
  @@index([success, createdAt])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model UserRole {
  id           String   @id @default(cuid())
  userId       String
  roleId       String
  assignedById String?
  assignedAt   DateTime @default(now())

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("UserRoleAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@index([roleId])
  @@index([assignedById])
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  grantedAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model AuditLog {
  id           String             @id @default(cuid())
  category     AuditCategory
  action       String
  actorId      String?
  targetUserId String?
  targetType   ContentTargetType?
  targetId     String?
  requestId    String?
  ipHash       String?
  userAgent    String?
  meta         Json?
  createdAt    DateTime           @default(now())

  actor      User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([category, createdAt])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
}

model UserProfile {
  id                    String                    @id @default(cuid())
  userId                String                    @unique
  username              String?                   @unique
  headline              String?
  bio                   String?
  company               String?
  roleTitle             String?
  websiteUrl            String?
  linkedInUrl           String?
  coverImageUrl         String?
  countryCode           String?                   @default("PK")
  city                  String?
  officeAddress         String?
  primaryRegionId       String?
  isLawyer              Boolean                   @default(false)
  yearsExperience       Int?
  consultationStatus    ConsultationAvailability?
  completionPercentage  Int                       @default(0)
  completionState       ProfileCompletionState    @default(NOT_STARTED)
  onboardingStep        String?
  onboardingChecklist   Json?
  onboardingCompletedAt DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  primaryRegion Region? @relation(fields: [primaryRegionId], references: [id], onDelete: SetNull)

  @@index([primaryRegionId])
  @@index([isLawyer])
}

model UserProfileVisibility {
  userId                      String                 @id
  emailVisibility             ProfileVisibilityLevel @default(MEMBERS_ONLY)
  phoneVisibility             ProfileVisibilityLevel @default(PRIVATE)
  headlineVisibility          ProfileVisibilityLevel @default(PUBLIC)
  bioVisibility               ProfileVisibilityLevel @default(PUBLIC)
  locationVisibility          ProfileVisibilityLevel @default(PUBLIC)
  companyVisibility           ProfileVisibilityLevel @default(PUBLIC)
  experienceVisibility        ProfileVisibilityLevel @default(PUBLIC)
  educationVisibility         ProfileVisibilityLevel @default(PUBLIC)
  certificationsVisibility    ProfileVisibilityLevel @default(PUBLIC)
  skillsVisibility            ProfileVisibilityLevel @default(PUBLIC)
  languagesVisibility         ProfileVisibilityLevel @default(PUBLIC)
  websiteVisibility           ProfileVisibilityLevel @default(PUBLIC)
  socialLinksVisibility       ProfileVisibilityLevel @default(PUBLIC)
  activityAnalyticsVisibility ProfileVisibilityLevel @default(PUBLIC)
  badgesVisibility            ProfileVisibilityLevel @default(PUBLIC)
  updatedAt                   DateTime               @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserExperience {
  id             String    @id @default(cuid())
  userId         String
  title          String
  organization   String
  location       String?
  employmentType String?
  description    String?
  startDate      DateTime?
  endDate        DateTime?
  isCurrent      Boolean   @default(false)
  sortOrder      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model UserEducation {
  id           String    @id @default(cuid())
  userId       String
  institution  String
  degree       String?
  fieldOfStudy String?
  description  String?
  startDate    DateTime?
  endDate      DateTime?
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model UserCertification {
  id            String    @id @default(cuid())
  userId        String
  name          String
  issuer        String?
  credentialId  String?
  credentialUrl String?
  issuedAt      DateTime?
  expiresAt     DateTime?
  description   String?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model UserSkill {
  id               String   @id @default(cuid())
  userId           String
  name             String
  yearsExperience  Int?
  endorsementCount Int      @default(0)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([name])
  @@index([userId, sortOrder])
}

model UserLanguage {
  id          String   @id @default(cuid())
  userId      String
  name        String
  proficiency String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, sortOrder])
}

model UserAward {
  id          String    @id @default(cuid())
  userId      String
  title       String
  issuer      String?
  description String?
  awardUrl    String?
  awardedAt   DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model UserSocialLink {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  label     String?
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model UserProfileView {
  id            String   @id @default(cuid())
  profileUserId String
  viewerUserId  String?
  ipHash        String?
  userAgent     String?
  referer       String?
  viewedAt      DateTime @default(now())

  profileUser User  @relation("ProfileViewsReceived", fields: [profileUserId], references: [id], onDelete: Cascade)
  viewerUser  User? @relation("ProfileViewsGiven", fields: [viewerUserId], references: [id], onDelete: SetNull)

  @@index([profileUserId, viewedAt])
  @@index([viewerUserId, viewedAt])
}

model UserActivityDaily {
  id                    String   @id @default(cuid())
  userId                String
  activityDate          DateTime
  discussionCount       Int      @default(0)
  answerCount           Int      @default(0)
  commentCount          Int      @default(0)
  caseCount             Int      @default(0)
  reactionReceivedCount Int      @default(0)
  profileViewCount      Int      @default(0)
  badgeCount            Int      @default(0)
  engagementScore       Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityDate])
  @@index([activityDate])
  @@index([userId, activityDate])
}

model UserStats {
  userId                String    @id
  discussionCount       Int       @default(0)
  answerCount           Int       @default(0)
  commentCount          Int       @default(0)
  caseCount             Int       @default(0)
  acceptedAnswerCount   Int       @default(0)
  followerCount         Int       @default(0)
  bookmarkCount         Int       @default(0)
  reactionReceivedCount Int       @default(0)
  profileViewCount      Int       @default(0)
  contributionScore     Int       @default(0)
  lastContributionAt    DateTime?
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserGamification {
  userId             String    @id
  totalPoints        Int       @default(0)
  level              Int       @default(1)
  badgesCount        Int       @default(0)
  likesReceived      Int       @default(0)
  likesGiven         Int       @default(0)
  acceptedAnswers    Int       @default(0)
  casesPublished     Int       @default(0)
  boostsUsed         Int       @default(0)
  streakDays         Int       @default(0)
  bestRank           Int?
  lastContributionAt DateTime?
  lastCalculatedAt   DateTime?
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GamificationEvent {
  id           String                @id @default(cuid())
  userId       String
  eventType    GamificationEventType
  pointsDelta  Int
  discussionId String?
  answerId     String?
  commentId    String?
  caseId       String?
  metadata     Json?
  createdAt    DateTime              @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussion Discussion? @relation(fields: [discussionId], references: [id], onDelete: SetNull)
  answer     Answer?     @relation(fields: [answerId], references: [id], onDelete: SetNull)
  comment    Comment?    @relation(fields: [commentId], references: [id], onDelete: SetNull)
  caseRecord CaseRecord? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
}

model Badge {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  iconName      String?
  pointsAwarded Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users UserBadge[]
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String
  awardedById String?
  reason      String?
  awardedAt   DateTime @default(now())

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedBy User? @relation("BadgeAwardedBy", fields: [awardedById], references: [id], onDelete: SetNull)

  @@unique([userId, badgeId])
  @@index([badgeId, awardedAt])
  @@index([awardedById])
}

model Organization {
  id          String                 @id @default(cuid())
  slug        String                 @unique
  name        String
  description String?
  logoUrl     String?
  websiteUrl  String?
  type        OrganizationType       @default(LAW_FIRM)
  visibility  OrganizationVisibility @default(PUBLIC)
  ownerId     String?
  verifiedAt  DateTime?
  createdAt   DateTime               @default(now())
